{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":automergeDigest",
    ":automergePatch"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update versioned ARGs in Dockerfiles",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)\\nARG \\w+=(?<currentValue>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "Update go install versions in Dockerfiles",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/"
      ],
      "matchStrings": [
        "go install (?<depName>[^@]+)@(?<currentValue>v\\S+)"
      ],
      "datasourceTemplate": "go"
    }
  ],
  "packageRules": []
}
